@using Radzen
@using Radzen.Blazor
@inherits LayoutComponentBase
<RadzenLayout Style="grid-template-areas: 'rz-header rz-header' 'rz-sidebar rz-body';">
    <RadzenHeader>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0">
            <RadzenSidebarToggle Click="@(() => sidebarExpanded = !sidebarExpanded)" />
            <RadzenLink Path="/" Style="text-decoration: none; display: flex; align-items: center; color: var(--rz-header-color);">
                <RadzenIcon Icon="broadcast_on_home" Style="color: var(--rz-danger); margin-right: 8px;" />
                <RadzenText Text="TikTok Tracker" Style="font-weight: bold; margin: 0; font-size: 1.25rem;" />
            </RadzenLink>
        </RadzenStack>
    </RadzenHeader>
    <RadzenSidebar Expanded="@sidebarExpanded" ExpandedChanged="@(v => sidebarExpanded = v)">
        <NavMenu />
    </RadzenSidebar>
    <RadzenBody>
        <div class="rz-p-4">
            @Body
        </div>
    </RadzenBody>
</RadzenLayout>

<RadzenComponents />

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    bool sidebarExpanded = true;
}
