@inherits LayoutComponentBase
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager

<div class="page text-bg-light">
    <main class="container py-4">
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark rounded shadow-sm mb-4">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" href="/"><i class="bi bi-broadcast"></i> TikTok Tracker</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="/">Dashboard</a>
                        </li>
                        <AuthorizeView>
                            <Authorized>
                                <li class="nav-item">
                                    <a class="nav-link" href="/admin">Manage</a>
                                </li>
                                <li class="nav-item">
                                    <button class="nav-link btn btn-link" @onclick="Logout">Logout</button>
                                </li>
                            </Authorized>
                            <NotAuthorized>
                                <li class="nav-item">
                                    <a class="nav-link" href="/login">Admin Login</a>
                                </li>
                            </NotAuthorized>
                        </AuthorizeView>
                    </ul>
                </div>
            </div>
        </nav>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private void Logout()
    {
        var provider = (TikTokTracker.Web.Services.SimpleAuthStateProvider)AuthStateProvider;
        provider.Logout();
        NavManager.NavigateTo("/");
    }
}
