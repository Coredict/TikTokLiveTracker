@inherits LayoutComponentBase
@inject NavigationManager NavManager

<div class="page">
    <header class="app-header shadow-sm mb-4">
        <div class="container d-flex justify-content-between align-items-center h-100 px-4">
            <a class="header-brand fw-bold text-white text-decoration-none" href="/">
                <i class="bi bi-broadcast text-danger me-2"></i> TikTok Tracker
            </a>
            <nav class="header-nav">
                <a class="nav-link-custom ms-4" href="/">Dashboard</a>
                <a class="nav-link-custom ms-4" href="/login">Admin</a>
            </nav>
        </div>
    </header>

    <main class="container">
        <article class="content">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
