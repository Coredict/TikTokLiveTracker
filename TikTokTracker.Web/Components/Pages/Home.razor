@page "/"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using TikTokTracker.Web.Data
@using TikTokTracker.Web.Models
@using TikTokTracker.Web.Services
@inject IDbContextFactory<AppDbContext> DbFactory
@inject TikTokTrackerService TrackerService
@inject IJSRuntime JSRuntime
@implements IDisposable

<PageTitle>TikTok Tracker Dashboard</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold text-white"><i class="bi bi-broadcast text-danger"></i> TikTok Live Tracker</h1>
        <a href="/admin" class="btn btn-outline-secondary">
            <i class="bi bi-gear"></i> Manage Accounts
        </a>
    </div>

    @if (errorMessage != null)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    else if (accounts == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2 text-muted">Loading data...</p>
        </div>
    }
    else
    {
        @if (!accounts.Any())
        {
            <div class="alert alert-info shadow-sm">
                <i class="bi bi-info-circle me-2"></i> No accounts are currently being tracked.
                <a href="/admin" class="alert-link">Add some in the Admin panel</a>.
            </div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3 mb-5">
                @foreach (var account in accounts.OrderByDescending(a => a.IsOnline).ThenByDescending(a => a.CurrentCoins))
                {
                    <div class="col">
                        <div class="card h-100 account-card">
                            <div class="card-body position-relative pt-4">

                                @if (account.IsOnline)
                                {
                                    <span class="position-absolute top-0 end-0 mt-3 me-3 text-danger d-flex align-items-center fw-bold">
                                        <span class="spinner-grow spinner-grow-sm me-2" role="status" aria-hidden="true" style="width: 0.75rem; height: 0.75rem;"></span>
                                        LIVE
                                    </span>
                                }
                                else
                                {
                                    <span class="position-absolute top-0 end-0 mt-3 me-3 badge badge-discord">
                                        OFFLINE
                                    </span>
                                }

                                <div class="position-absolute bottom-0 end-0 mb-3 me-3">
                                    <div class="record-toggle-container shadow-sm">
                                        <div class="form-check form-switch m-0 d-flex align-items-center">
                                            <input class="form-check-input m-0" type="checkbox" id="record-@account.Id" 
                                                   checked="@account.AutoRecord" 
                                                   @onchange="@(e => ToggleAutoRecord(account, e))">
                                        </div>
                                        <label class="record-toggle-label m-0" for="record-@account.Id">
                                            Auto-Record
                                        </label>
                                    </div>
                                </div>

                                <div class="d-flex align-items-center mb-3">
                                    <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center shadow-sm" style="width: 45px; height: 45px; font-size: 1.25rem; font-weight: bold; background-color: var(--discord-blurple) !important;">
                                        @account.Username.FirstOrDefault().ToString().ToUpper()
                                    </div>
                                    <div class="ms-3">
                                        <h5 class="card-title mb-0 fs-5 fw-bold">@@@account.Username</h5>
                                    </div>
                                </div>

                                <div class="mt-4 row text-center">
                                    <div class="col-6 border-end">
                                        <div class="text-muted small text-uppercase fw-bold">Coins Today</div>
                                        <div class="fs-3 fw-bold text-warning">
                                            <i class="bi bi-gem"></i> @account.CurrentCoins.ToString("N0")
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="text-muted small text-uppercase fw-bold">Viewers</div>
                                        <div class="fs-3 fw-bold text-info">
                                            <i class="bi bi-people"></i> @(account.IsOnline ? account.ViewerCount.ToString("N0") : "-")
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="card-footer bg-transparent border-top-0 pt-0 pb-3">
                                <a href="@account.StreamUrl" target="_blank" class="btn @(account.IsOnline ? "btn-danger" : "btn-outline-secondary") w-100 fw-bold py-2">
                                    <i class="bi bi-box-arrow-up-right"></i> @(account.IsOnline ? "Watch Stream" : "View Profile")
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        <div class="row g-4">
            <!-- Recent Gifts -->
            <div class="col-xl-6">
                <div class="card shadow-sm border-0 h-100 bg-transparent">
                    <div class="card-header bg-transparent border-bottom-0 pt-0 px-0 d-flex justify-content-between align-items-center mb-3">
                        <h3 class="mb-0 fs-5 fw-bold text-white">Recent Gifts Feed</h3>
                        <button class="btn btn-sm btn-outline-info" @onclick="ExportGifts">
                            <i class="bi bi-download"></i> Export
                        </button>
                    </div>
                    <div class="fixed-list-container">
                        <div class="table-responsive">
                            <table class="table table-sm table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Time</th>
                                        <th>To</th>
                                        <th>Sender</th>
                                        <th>Gift</th>
                                        <th>Diamonds</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (recentGifts == null)
                                    {
                                        <tr><td colspan="5" class="text-center py-4 text-muted">Loading gifts...</td></tr>
                                    }
                                    else if (!recentGifts.Any())
                                    {
                                        <tr><td colspan="5" class="text-center py-4 text-muted">No gifts recorded yet.</td></tr>
                                    }
                                    else
                                    {
                                        @foreach (var gift in recentGifts)
                                        {
                                            <tr>
                                                <td class="text-muted small">@gift.Timestamp.ToLocalTime().ToString("HH:mm:ss")</td>
                                                <td><span class="badge badge-discord">@@@gift.Account?.Username</span></td>
                                                <td class="small">
                                                    <strong>@gift.SenderNickname</strong><br />
                                                    <span class="text-muted">@@@gift.SenderUsername</span>
                                                </td>
                                                <td class="small">@gift.GiftName (@gift.Amount)</td>
                                                <td><span class="text-warning small">💎</span> @gift.TotalDiamonds</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                        @if (totalGiftsCount > pageSize)
                        {
                            <nav class="mt-auto pt-3">
                                <ul class="pagination pagination-sm justify-content-center mb-0">
                                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                        <button class="page-link shadow-none" @onclick="() => ChangePage(currentPage - 1)">Prev</button>
                                    </li>
                                    <li class="page-item disabled"><span class="page-link border-0">@currentPage</span></li>
                                    <li class="page-item @(currentPage * pageSize >= totalGiftsCount ? "disabled" : "")">
                                        <button class="page-link shadow-none" @onclick="() => ChangePage(currentPage + 1)">Next</button>
                                    </li>
                                </ul>
                            </nav>
                        }
                    </div>
                </div>
            </div>

            <!-- Top Gifters -->
            <div class="col-xl-6">
                <div class="card shadow-sm border-0 h-100 bg-transparent">
                    <div class="card-header bg-transparent border-bottom-0 pt-0 px-0 mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h3 class="mb-0 fs-5 fw-bold text-white">Top Gifters</h3>
                            <button class="btn btn-sm btn-outline-info" @onclick="ExportSummaries">
                                <i class="bi bi-download"></i> Export
                            </button>
                        </div>
                        <select class="form-select form-select-sm border-0 bg-dark text-white" style="background-color: var(--discord-bg-deep) !important;" @onchange="OnRecipientChanged">
                            <option value="">All tracked accounts</option>
                            @if (accounts != null)
                            {
                                @foreach (var acc in accounts)
                                {
                                    <option value="@acc.Id">@@@acc.Username</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="fixed-list-container">
                        <div class="table-responsive">
                            <table class="table table-sm table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Target</th>
                                        <th>Gifter</th>
                                        <th>Diamonds</th>
                                        <th>Updated</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (topGifters == null)
                                    {
                                        <tr><td colspan="4" class="text-center py-4 text-muted">Loading leaderboard...</td></tr>
                                    }
                                    else if (!topGifters.Any())
                                    {
                                        <tr><td colspan="4" class="text-center py-4 text-muted">No interactions yet.</td></tr>
                                    }
                                    else
                                    {
                                        @foreach (var summary in topGifters)
                                        {
                                            <tr>
                                                <td><span class="badge badge-discord">@@@summary.Account?.Username</span></td>
                                                <td class="small">
                                                    <strong>@summary.SenderNickname</strong><br />
                                                    <span class="text-muted">@@@summary.SenderUsername</span>
                                                </td>
                                                <td class="fw-bold">
                                                    <span class="text-warning small">💎</span> @summary.TotalDiamonds.ToString("N0")
                                                </td>
                                                <td class="text-muted small">@summary.LastGiftTime.ToLocalTime().ToString("MMM dd")</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                        @if (totalSummaryCount > pageSize)
                        {
                            <nav class="mt-auto pt-3">
                                <ul class="pagination pagination-sm justify-content-center mb-0">
                                    <li class="page-item @(currentSummaryPage == 1 ? "disabled" : "")">
                                        <button class="page-link shadow-none" @onclick="() => ChangeSummaryPage(currentSummaryPage - 1)">Prev</button>
                                    </li>
                                    <li class="page-item disabled"><span class="page-link border-0">@currentSummaryPage</span></li>
                                    <li class="page-item @(currentSummaryPage * pageSize >= totalSummaryCount ? "disabled" : "")">
                                        <button class="page-link shadow-none" @onclick="() => ChangeSummaryPage(currentSummaryPage + 1)">Next</button>
                                    </li>
                                </ul>
                            </nav>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<TikTokAccount>? accounts;
    private List<GiftTransaction>? recentGifts;
    private List<GifterSummary>? topGifters;
    private string? errorMessage;
    private System.Threading.Timer? _timer;

    // Pagination/Filtering
    private int currentPage = 1;
    private int currentSummaryPage = 1;
    private int pageSize = 10;
    private int totalGiftsCount = 0;
    private int totalSummaryCount = 0;
    private int? selectedRecipientId;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAllData();

        _timer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await RefreshAllData();
                StateHasChanged();
            });
        }, null, 1000, 1000);
    }

    private async Task RefreshAllData()
    {
        try
        {
            // Use in-memory cache from the service instead of querying DB
            var allAccounts = TrackerService.CachedAccounts;
            var allGifts = TrackerService.CachedRecentGifts;
            var allSummaries = TrackerService.CachedTopGifters;

            accounts = allAccounts.ToList();

            // Pagination/Filtering in memory for the most recent 50 items stored in cache
            totalGiftsCount = allGifts.Count;
            recentGifts = allGifts
                .Skip((currentPage - 1) * pageSize)
                .Take(pageSize)
                .ToList();

            var summaryQuery = allSummaries.AsQueryable();
            if (selectedRecipientId.HasValue)
            {
                summaryQuery = summaryQuery.Where(s => s.TikTokAccountId == selectedRecipientId.Value);
            }
            
            var filteredSummaries = summaryQuery.ToList();
            totalSummaryCount = filteredSummaries.Count;
            topGifters = filteredSummaries
                .Skip((currentSummaryPage - 1) * pageSize)
                .Take(pageSize)
                .ToList();
        }
        catch (Exception ex)
        {
            errorMessage = $"Cache error: {ex.Message}";
        }
    }

    // Keep these empty or remove them as they are now handled by RefreshAllData/Cache
    private Task LoadRecentGifts(AppDbContext db) => Task.CompletedTask;
    private Task LoadTopGifters(AppDbContext db) => Task.CompletedTask;

    private async Task ToggleAutoRecord(TikTokAccount account, ChangeEventArgs e)
    {
        var isChecked = (bool)(e.Value ?? false);
        account.AutoRecord = isChecked;

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var dbAccount = await db.Accounts.FindAsync(account.Id);
            if (dbAccount != null)
            {
                dbAccount.AutoRecord = isChecked;
                await db.SaveChangesAsync();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error updating auto-record: {ex.Message}";
        }
    }

    private async Task ChangePage(int newPage)
    {
        currentPage = newPage;
        await InvokeAsync(RefreshAllData);
    }

    private async Task ChangeSummaryPage(int newPage)
    {
        currentSummaryPage = newPage;
        await InvokeAsync(RefreshAllData);
    }

    private async Task OnRecipientChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id)) selectedRecipientId = id;
        else selectedRecipientId = null;
        currentSummaryPage = 1;
        await InvokeAsync(RefreshAllData);
    }

    private async Task ExportGifts()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var gifts = await db.Gifts
            .Include(g => g.Account)
            .OrderByDescending(g => g.Timestamp)
            .Select(g => new {
                Time = g.Timestamp.ToLocalTime(),
                To = g.Account != null ? "@" + g.Account.Username : "N/A",
                Sender = g.SenderNickname + " (@" + g.SenderUsername + ")",
                Gift = g.GiftName,
                Diamonds = g.TotalDiamonds
            })
            .ToListAsync();
        
        var json = System.Text.Json.JsonSerializer.Serialize(gifts, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        await JSRuntime.InvokeVoidAsync("saveAsFile", $"gifts_export_{DateTime.Now:yyyyMMdd}.json", json);
    }

    private async Task ExportSummaries()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        
        var query = db.GifterSummaries.AsNoTracking().AsQueryable();
        string filenamePrefix = "top_gifters_all";

        if (selectedRecipientId.HasValue)
        {
            query = query.Where(s => s.TikTokAccountId == selectedRecipientId.Value);
            var accountName = accounts?.FirstOrDefault(a => a.Id == selectedRecipientId.Value)?.Username ?? "unknown";
            filenamePrefix = $"top_gifters_{accountName}";
        }

        var summaries = await query
            .Include(g => g.Account)
            .OrderByDescending(g => g.TotalDiamonds)
            .Select(s => new {
                Recipient = s.Account != null ? "@" + s.Account.Username : "N/A",
                Sender = s.SenderNickname + " (@" + s.SenderUsername + ")",
                TotalDiamonds = s.TotalDiamonds,
                TotalGifts = s.TotalGifts,
                LastSeen = s.LastGiftTime.ToLocalTime()
            })
            .ToListAsync();
        
        var json = System.Text.Json.JsonSerializer.Serialize(summaries, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        await JSRuntime.InvokeVoidAsync("saveAsFile", $"{filenamePrefix}_{DateTime.Now:yyyyMMdd_HHmm}.json", json);
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }
}
