@page "/"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using TikTokTracker.Web.Data
@using TikTokTracker.Web.Models
@using TikTokTracker.Web.Services
@using Radzen
@using Radzen.Blazor
@inject IDbContextFactory<AppDbContext> DbFactory
@inject TikTokTrackerService TrackerService
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@implements IDisposable

<PageTitle>TikTok Live Tracker</PageTitle>

<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" class="rz-mb-4">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
        <RadzenIcon Icon="broadcast_on_home" IconColor="var(--rz-danger)" Style="font-size: 2rem;" />
        <RadzenText TextStyle="TextStyle.H4" TagName="TagName.H1" class="rz-m-0" Text="TikTok Live Tracker" />
    </RadzenStack>
    <RadzenButton Click="@(() => NavManager.NavigateTo("/admin"))" Icon="settings" Text="Manage Accounts" ButtonStyle="ButtonStyle.Secondary" Variant="Variant.Outlined" />
</RadzenStack>

@if (errorMessage != null)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" Shade="Shade.Lighter">@errorMessage</RadzenAlert>
}
else if (accounts == null)
{
    <div class="rz-p-12 rz-text-align-center">
        <RadzenProgressBarCircular Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
        <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mt-4" Text="Loading data..." />
    </div>
}
else
{
    @if (!accounts.Any())
    {
        <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" Shade="Shade.Lighter">
            No accounts are currently being tracked. <RadzenLink Path="/admin" Text="Add some in the Admin panel" />.
        </RadzenAlert>
    }
    else
    {
        <RadzenContentContainer>
            <RadzenRow Gap="1rem" class="rz-mb-6">
                @foreach (var account in accounts.OrderByDescending(a => a.IsOnline).ThenByDescending(a => a.CoinsToday))
                {
                    <RadzenColumn Size="12" SizeMD="6" SizeLG="4">
                        <RadzenCard class="rz-h-100" Style="position: relative;">
                            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Start">
                                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
                                    <RadzenIcon Icon="account_circle" Style="color: var(--rz-primary-light); font-size: 48px;" />
                                    <RadzenText TextStyle="TextStyle.H6" Text="@("@" + account.Username)" class="rz-m-0" />
                                </RadzenStack>
                                <RadzenStack AlignItems="AlignItems.End" Gap="0.25rem">
                                    @if (account.IsOnline)
                                    {
                                        <RadzenBadge Text="LIVE" BadgeStyle="BadgeStyle.Success" IsPill="true" />
                                        @if (account.IsRecording)
                                        {
                                            <RadzenBadge Text="REC" BadgeStyle="BadgeStyle.Danger" IsPill="true" />
                                        }
                                    }
                                    else
                                    {
                                        <RadzenBadge Text="OFFLINE" BadgeStyle="BadgeStyle.Secondary" IsPill="true" />
                                    }
                                </RadzenStack>
                            </RadzenStack>

                            <RadzenRow class="rz-mt-6 rz-text-align-center">
                                <RadzenColumn Size="6" Style="border-right: var(--rz-border-base);">
                                    <RadzenText TextStyle="TextStyle.Overline" Text="Coins Today" class="rz-display-block rz-mb-1" />
                                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Gap="0.25rem">
                                        <RadzenIcon Icon="monetization_on" IconColor="var(--rz-warning)" />
                                        <RadzenText TextStyle="TextStyle.H5" Text="@account.CoinsToday.ToString("N0")" class="rz-m-0 rz-color-warning" />
                                    </RadzenStack>
                                </RadzenColumn>
                                <RadzenColumn Size="6">
                                    <RadzenText TextStyle="TextStyle.Overline" Text="Viewers" class="rz-display-block rz-mb-1" />
                                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Gap="0.25rem">
                                        <RadzenIcon Icon="group" IconColor="var(--rz-info)" />
                                        <RadzenText TextStyle="TextStyle.H5" Text="@(account.IsOnline ? account.ViewerCount.ToString("N0") : "-")" class="rz-m-0 rz-color-info" />
                                    </RadzenStack>
                                </RadzenColumn>
                            </RadzenRow>

                            <a href="@account.StreamUrl" target="_blank" 
                               class="rz-button rz-button-md rz-variant-filled @(account.IsOnline ? "rz-danger" : "rz-light") rz-shade-default rz-mt-4 rz-w-100"
                               style="text-decoration: none; display: flex; align-items: center; justify-content: center; gap: 0.5rem;">
                                <RadzenIcon Icon="open_in_new" />
                                <span class="rz-button-text">@(account.IsOnline ? "Watch Stream" : "View Profile")</span>
                            </a>
                        </RadzenCard>
                    </RadzenColumn>
                }
            </RadzenRow>
        </RadzenContentContainer>
    }

    <RadzenRow Gap="2rem">
        <RadzenColumn Size="12" SizeXL="6">
            <RadzenCard Variant="Variant.Flat">
                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" class="rz-mb-4">
                    <RadzenText TextStyle="TextStyle.H5" Text="Recent Gifts Feed" class="rz-m-0" />
                    <RadzenButton Icon="download" Text="Export" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Info" Variant="Variant.Outlined" Click="@ExportGifts" />
                </RadzenStack>
                <RadzenDataGrid Data="@recentGifts" TItem="GiftTransaction" AllowPaging="false" Density="Density.Compact" class="rz-border-radius-1">
                    <Columns>
                        <RadzenDataGridColumn TItem="GiftTransaction" Title="Time" Width="100px">
                            <Template Context="gift">
                                <RadzenText TextStyle="TextStyle.Body2" Text="@gift.Timestamp.ToLocalTime().ToString("HH:mm:ss")" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="GiftTransaction" Title="To" Width="120px">
                            <Template Context="gift">
                                <RadzenBadge Text="@("@" + (gift.Account?.Username ?? "Unknown"))" IsPill="true" BadgeStyle="BadgeStyle.Light" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="GiftTransaction" Title="Sender">
                            <Template Context="gift">
                                <RadzenText TextStyle="TextStyle.Body2"><strong>@gift.SenderNickname</strong></RadzenText>
                                <RadzenText TextStyle="TextStyle.Caption" Text="@("@" + gift.SenderUsername)" class="rz-display-block" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="GiftTransaction" Title="Gift">
                            <Template Context="gift">
                                <RadzenText TextStyle="TextStyle.Body2" Text="@($"{gift.GiftName} ({gift.Amount})")" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="GiftTransaction" Title="Diamonds" Width="100px">
                            <Template Context="gift">
                                <RadzenText TextStyle="TextStyle.Body2" class="rz-color-warning">💎 @gift.TotalDiamonds</RadzenText>
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
                @if (totalGiftsCount > pageSize)
                {
                    <RadzenPager Count="@totalGiftsCount" PageSize="@pageSize" PageNumbersCount="3" PageChanged="@(args => ChangePage(args.PageIndex + 1))" class="rz-mt-4" />
                }
            </RadzenCard>
        </RadzenColumn>

        <RadzenColumn Size="12" SizeXL="6">
            <RadzenCard Variant="Variant.Flat">
                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" class="rz-mb-2">
                    <RadzenText TextStyle="TextStyle.H5" Text="Top Gifters" class="rz-m-0" />
                    <RadzenButton Icon="download" Text="Export" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Info" Variant="Variant.Outlined" Click="@ExportSummaries" />
                </RadzenStack>
                <RadzenDropDown TValue="int?" Data="@accounts" TextProperty="Username" ValueProperty="Id" 
                                Placeholder="All tracked accounts" Value="@selectedRecipientId" Change="@OnRecipientChanged" 
                                class="rz-w-100 rz-mb-4" AllowClear="true" />
                
                <RadzenDataGrid Data="@topGifters" TItem="GifterSummary" AllowPaging="false" Density="Density.Compact" class="rz-border-radius-1">
                    <Columns>
                        <RadzenDataGridColumn TItem="GifterSummary" Title="Target" Width="120px">
                            <Template Context="summary">
                                <RadzenBadge Text="@("@" + (summary.Account?.Username ?? "Unknown"))" IsPill="true" BadgeStyle="BadgeStyle.Light" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="GifterSummary" Title="Gifter">
                            <Template Context="summary">
                                <RadzenText TextStyle="TextStyle.Body2"><strong>@summary.SenderNickname</strong></RadzenText>
                                <RadzenText TextStyle="TextStyle.Caption" Text="@("@" + summary.SenderUsername)" class="rz-display-block" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="GifterSummary" Title="Diamonds" Width="120px">
                            <Template Context="summary">
                                <RadzenText TextStyle="TextStyle.Body2" class="rz-color-warning" Style="font-weight: bold;">💎 @summary.TotalDiamonds.ToString("N0")</RadzenText>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="GifterSummary" Title="Updated" Width="100px">
                            <Template Context="summary">
                                <RadzenText TextStyle="TextStyle.Body2" Text="@summary.LastGiftTime.ToLocalTime().ToString("MMM dd")" />
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
                @if (totalSummaryCount > pageSize)
                {
                    <RadzenPager Count="@totalSummaryCount" PageSize="@pageSize" PageNumbersCount="3" PageChanged="@(args => ChangeSummaryPage(args.PageIndex + 1))" class="rz-mt-4" />
                }
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>
}

@code {
    private List<TikTokAccount>? accounts;
    private List<GiftTransaction>? recentGifts;
    private List<GifterSummary>? topGifters;
    private string? errorMessage;
    private System.Threading.Timer? _timer;

    // Pagination/Filtering
    private int currentPage = 1;
    private int currentSummaryPage = 1;
    private int pageSize = 10;
    private int totalGiftsCount = 0;
    private int totalSummaryCount = 0;
    private int? selectedRecipientId;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAllData();

        _timer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await RefreshAllData();
                StateHasChanged();
            });
        }, null, 1000, 1000);
    }

    private async Task RefreshAllData()
    {
        try
        {
            var allAccounts = TrackerService.CachedAccounts;
            var allGifts = TrackerService.CachedRecentGifts;
            var allSummaries = TrackerService.CachedTopGifters;

            accounts = allAccounts.ToList();

            totalGiftsCount = allGifts.Count;
            recentGifts = allGifts
                .Skip((currentPage - 1) * pageSize)
                .Take(pageSize)
                .ToList();

            var summaryQuery = allSummaries.AsQueryable();
            if (selectedRecipientId.HasValue)
            {
                summaryQuery = summaryQuery.Where(s => s.TikTokAccountId == selectedRecipientId.Value);
            }
            
            var filteredSummaries = summaryQuery.ToList();
            totalSummaryCount = filteredSummaries.Count;
            topGifters = filteredSummaries
                .Skip((currentSummaryPage - 1) * pageSize)
                .Take(pageSize)
                .ToList();
        }
        catch (Exception ex)
        {
            errorMessage = $"Cache error: {ex.Message}";
        }
    }

    private async Task ChangePage(int newPage)
    {
        currentPage = newPage;
        await InvokeAsync(RefreshAllData);
    }

    private async Task ChangeSummaryPage(int newPage)
    {
        currentSummaryPage = newPage;
        await InvokeAsync(RefreshAllData);
    }

    private async Task OnRecipientChanged(object value)
    {
        if (value is int id) selectedRecipientId = id;
        else selectedRecipientId = null;
        currentSummaryPage = 1;
        await InvokeAsync(RefreshAllData);
    }

    private async Task ExportGifts()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var gifts = await db.Gifts
            .Include(g => g.Account)
            .OrderByDescending(g => g.Timestamp)
            .Select(g => new {
                Time = g.Timestamp.ToLocalTime(),
                To = g.Account != null ? "@" + g.Account.Username : "N/A",
                Sender = g.SenderNickname + " (@" + g.SenderUsername + ")",
                Gift = g.GiftName,
                Diamonds = g.TotalDiamonds
            })
            .ToListAsync();
        
        var json = System.Text.Json.JsonSerializer.Serialize(gifts, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        await JSRuntime.InvokeVoidAsync("saveAsFile", $"gifts_export_{DateTime.Now:yyyyMMdd}.json", json);
    }

    private async Task ExportSummaries()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        
        var query = db.GifterSummaries.AsNoTracking().AsQueryable();
        string filenamePrefix = "top_gifters_all";

        if (selectedRecipientId.HasValue)
        {
            query = query.Where(s => s.TikTokAccountId == selectedRecipientId.Value);
            var accountName = accounts?.FirstOrDefault(a => a.Id == selectedRecipientId.Value)?.Username ?? "unknown";
            filenamePrefix = $"top_gifters_{accountName}";
        }

        var summaries = await query
            .Include(g => g.Account)
            .OrderByDescending(g => g.TotalDiamonds)
            .Select(s => new {
                Recipient = s.Account != null ? "@" + s.Account.Username : "N/A",
                Sender = s.SenderNickname + " (@" + s.SenderUsername + ")",
                TotalDiamonds = s.TotalDiamonds,
                TotalGifts = s.TotalGifts,
                LastSeen = s.LastGiftTime.ToLocalTime()
            })
            .ToListAsync();
        
        var json = System.Text.Json.JsonSerializer.Serialize(summaries, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        await JSRuntime.InvokeVoidAsync("saveAsFile", $"{filenamePrefix}_{DateTime.Now:yyyyMMdd_HHmm}.json", json);
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }
}
