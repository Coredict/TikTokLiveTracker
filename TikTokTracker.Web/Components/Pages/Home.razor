@page "/"
@using Microsoft.EntityFrameworkCore
@using TikTokTracker.Web.Data
@using TikTokTracker.Web.Models
@inject AppDbContext DbContext
@implements IDisposable

<PageTitle>TikTok Tracker Dashboard</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-broadcast text-danger"></i> TikTok Live Tracker</h1>
        <a href="/admin" class="btn btn-outline-secondary">
            <i class="bi bi-gear"></i> Manage Accounts
        </a>
    </div>

    @if (accounts == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2 text-muted">Loading tracked accounts...</p>
        </div>
    }
    else if (!accounts.Any())
    {
        <div class="alert alert-info shadow-sm">
            <i class="bi bi-info-circle me-2"></i> No accounts are currently being tracked. 
            <a href="/admin" class="alert-link">Add some in the Admin panel</a>.
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var account in accounts.OrderByDescending(a => a.IsOnline).ThenByDescending(a => a.CurrentCoins))
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 bg-light">
                        <div class="card-body position-relative">
                            
                            @if (account.IsOnline)
                            {
                                <span class="position-absolute top-0 end-0 mt-3 me-3 text-danger d-flex align-items-center fw-bold">
                                    <span class="spinner-grow spinner-grow-sm me-2" role="status" aria-hidden="true" style="width: 0.75rem; height: 0.75rem;"></span>
                                    LIVE
                                </span>
                            }
                            else
                            {
                                <span class="position-absolute top-0 end-0 mt-3 me-3 text-secondary badge bg-light border text-dark">
                                    OFFLINE
                                </span>
                            }

                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center" style="width: 50px; height: 50px; font-size: 1.5rem;">
                                    @account.Username.FirstOrDefault().ToString().ToUpper()
                                </div>
                                <div class="ms-3">
                                    <h5 class="card-title mb-0 fs-4 fw-bold text-dark">@@@account.Username</h5>
                                </div>
                            </div>

                            <div class="mt-4 row text-center">
                                <div class="col-6 border-end">
                                    <div class="text-muted small text-uppercase fw-bold">Coins Today</div>
                                    <div class="fs-3 fw-bold text-warning">
                                        <i class="bi bi-gem"></i> @account.CurrentCoins.ToString("N0")
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="text-muted small text-uppercase fw-bold">Viewers</div>
                                    <div class="fs-3 fw-bold text-info">
                                        <i class="bi bi-people"></i> @account.ViewerCount.ToString("N0")
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-top-0 pb-3">
                            <a href="@account.StreamUrl" target="_blank" class="btn @(account.IsOnline ? "btn-danger" : "btn-outline-secondary") w-100 fw-bold">
                                <i class="bi bi-box-arrow-up-right"></i> @(account.IsOnline ? "Watch Stream" : "View Profile")
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<TikTokAccount> accounts;
    private System.Threading.Timer _timer;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
        
        // Refresh UI every 5 seconds to show real-time updates from background service
        _timer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await LoadDataAsync();
                StateHasChanged();
            });
        }, null, 5000, 5000);
    }

    private async Task LoadDataAsync()
    {
        accounts = await DbContext.Accounts.AsNoTracking().ToListAsync();
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }
}
