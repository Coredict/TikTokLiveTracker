@page "/admin"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using Microsoft.EntityFrameworkCore
@using TikTokTracker.Web.Data
@using TikTokTracker.Web.Models
@inject AppDbContext DbContext

<PageTitle>Admin Panel</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Admin Panel - Tracked Accounts</h2>
    </div>

    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <h5 class="card-title">Add New Account</h5>
            <div class="input-group">
                <input type="text" class="form-control" @bind="newUsername" placeholder="TikTok Username (without @@)" />
                <button class="btn btn-success" @onclick="AddAccount">Add Account</button>
            </div>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Username</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (accounts == null)
                {
                    <tr><td colspan="3" class="text-center">Loading...</td></tr>
                }
                else if (!accounts.Any())
                {
                    <tr><td colspan="3" class="text-center">No accounts tracked.</td></tr>
                }
                else
                {
                    @foreach (var account in accounts)
                    {
                        <tr>
                            <td><strong>@account.Username</strong></td>
                            <td>
                                @if (account.IsOnline)
                                {
                                    <span class="badge bg-success">Online</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Offline</span>
                                }
                            </td>
                            <td>
                                <button class="btn btn-danger btn-sm" @onclick="() => RemoveAccount(account)">
                                    <i class="bi bi-trash"></i> Remove
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<TikTokAccount> accounts = new();
    private string newUsername = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadAccounts();
    }

    private async Task LoadAccounts()
    {
        accounts = await DbContext.Accounts.ToListAsync();
    }

    private async Task AddAccount()
    {
        if (!string.IsNullOrWhiteSpace(newUsername))
        {
            var username = newUsername.Trim().Replace("@", "");
            if (!await DbContext.Accounts.AnyAsync(a => a.Username == username))
            {
                DbContext.Accounts.Add(new TikTokAccount { Username = username });
                await DbContext.SaveChangesAsync();
                newUsername = "";
                await LoadAccounts();
            }
        }
    }

    private async Task RemoveAccount(TikTokAccount account)
    {
        DbContext.Accounts.Remove(account);
        await DbContext.SaveChangesAsync();
        await LoadAccounts();
    }
}
