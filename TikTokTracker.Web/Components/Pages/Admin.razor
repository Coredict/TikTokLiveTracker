@page "/admin"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using TikTokTracker.Web.Data
@using TikTokTracker.Web.Models
@using TikTokTracker.Web.Services
@using Radzen
@using Radzen.Blazor
@inject IDbContextFactory<AppDbContext> DbFactory
@inject TikTokTrackerService TrackerService
@inject AdminSessionService AdminSession
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@inject RecorderClient RecorderClient
@inject ISystemSettingsService SettingsService
@implements IDisposable

<PageTitle>Admin Panel</PageTitle>

<style>
    .rz-flex-wrap {
        flex-wrap: wrap !important;
    }

    .mobile-only {
        display: none;
    }

    @@media (max-width: 768px) {
        .mobile-hide {
            display: none !important;
        }
        .mobile-only {
            display: block !important;
        }
        .rz-w-xs-100 {
            width: 100% !important;
            display: block !important;
            margin-top: 10px;
        }
        .header-stack {
            flex-direction: column !important;
            align-items: flex-start !important;
        }
        .add-account-stack {
            flex-direction: column !important;
        }
        .add-account-input {
            width: 100% !important;
            margin-bottom: 10px !important;
        }
        .action-cell {
            padding: 0.25rem !important;
        }
        .rz-datagrid-data td {
            padding: 8px 4px !important;
        }
    }
</style>

@if (AdminSession.IsAdmin)
{

    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Wrap="FlexWrap.Wrap" class="rz-mb-4 rz-flex-wrap header-stack" Style="gap: 1rem;">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            <RadzenIcon Icon="admin_panel_settings" Style="font-size: 2rem;" />
            <RadzenText TextStyle="TextStyle.H4" TagName="TagName.H1" class="rz-m-0" Text="Admin Panel" />
        </RadzenStack>
        <RadzenButton Text="Logout" ButtonStyle="ButtonStyle.Secondary" Size="ButtonSize.Small" Variant="Variant.Outlined" Click="@Logout" class="rz-w-xs-100" />
    </RadzenStack>

    <RadzenCard class="rz-mb-4">
        <RadzenText TextStyle="TextStyle.H6" Text="Add New Account" class="rz-mb-3" />
        <RadzenStack Orientation="Orientation.Horizontal" Wrap="FlexWrap.Wrap" Gap="1rem" class="rz-flex-wrap add-account-stack">
            <input @bind="newUsername" placeholder="TikTok Username" class="rz-textbox rz-flex-grow-1 rz-w-xs-100 add-account-input" />
            <RadzenButton Text="Add" ButtonStyle="ButtonStyle.Success" Click="@AddAccount" class="rz-w-xs-100" />
        </RadzenStack>
        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" Shade="Shade.Lighter" class="rz-mt-2 rz-p-2">
                @statusMessage
            </RadzenAlert>
        }
    </RadzenCard>

    <RadzenCard class="rz-mb-4">
        <RadzenText TextStyle="TextStyle.H6" Text="TikTok Settings" class="rz-mb-3" />
        <RadzenStack Orientation="Orientation.Vertical" Gap="1rem">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem" Wrap="FlexWrap.Wrap">
                <RadzenText TextStyle="TextStyle.Body2" Text="Current Session ID:" class="rz-m-0" Style="min-width: 150px;" />
                <RadzenText TextStyle="TextStyle.Body1" class="rz-m-0">
                    <code>@(string.IsNullOrEmpty(currentSessionId) ? "Not Set" : currentSessionId)</code>
                </RadzenText>
                @if (isSessionIdFromConfig)
                {
                    <RadzenBadge Text="From Config (Default)" BadgeStyle="BadgeStyle.Info" IsPill="true" />
                }
            </RadzenStack>
            
            <RadzenStack Orientation="Orientation.Horizontal" Wrap="FlexWrap.Wrap" Gap="1rem" class="rz-flex-wrap add-account-stack">
                <input @bind="newSessionId" placeholder="New TikTok Session ID" class="rz-textbox rz-flex-grow-1 rz-w-xs-100 add-account-input" />
                <RadzenButton Text="Update" ButtonStyle="ButtonStyle.Primary" Click="@UpdateSessionId" class="rz-w-xs-100" />
            </RadzenStack>
        </RadzenStack>
    </RadzenCard>

    <RadzenDataGrid Data="@accounts" TItem="TikTokAccount" AllowPaging="true" PageSize="10" Density="Density.Compact" Responsive="true" class="rz-border-radius-1">
        <Columns>
            <RadzenDataGridColumn TItem="TikTokAccount" Title="Account">
                <Template Context="account">
                    <RadzenStack Orientation="Orientation.Vertical" Gap="0">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.25rem">
                            <RadzenIcon Icon="account_circle" Style="font-size: 1rem;" />
                            <strong style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 120px;">@account.Username</strong>
                        </RadzenStack>
                        <div class="mobile-only">
                            <RadzenText TextStyle="TextStyle.Caption" class="rz-color-warning">💎 @account.CoinsToday.ToString("N0")</RadzenText>
                        </div>
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="TikTokAccount" Title="Status" Width="80px">
                <Template Context="account">
                    @if (account.IsOnline)
                    {
                        <RadzenBadge Text="ON" BadgeStyle="BadgeStyle.Success" IsPill="true" />
                    }
                    else
                    {
                        <RadzenBadge Text="OFF" BadgeStyle="BadgeStyle.Secondary" IsPill="true" />
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="TikTokAccount" Title="Auto" Width="70px" TextAlign="TextAlign.Center">
                <Template Context="account">
                    <RadzenSwitch TValue="bool" Value="@account.AutoRecord" Change="@(v => OnToggleAccount(v, account))" Style="transform: scale(0.8);" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="TikTokAccount" Title="Coins" Width="100px" TextAlign="TextAlign.Right" HeaderCssClass="mobile-hide" CssClass="mobile-hide">
                <Template Context="account">
                    <RadzenText TextStyle="TextStyle.Body2" class="rz-color-warning">💎 @account.CoinsToday.ToString("N0")</RadzenText>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="TikTokAccount" Title="" Width="50px" TextAlign="TextAlign.Center">
                <Template Context="account">
                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.ExtraSmall" Variant="Variant.Text" Click="@(args => OnRemoveAccount(args, account))" />
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>

    <RadzenText TextStyle="TextStyle.H5" class="rz-mt-8 rz-mb-4">Recordings</RadzenText>
    
    <RadzenCard class="rz-mb-4" Style="border-left: 4px solid var(--rz-danger); padding: 1rem;">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Gap="0.5rem" class="rz-mb-4">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenIcon Icon="fiber_manual_record" Style="color: var(--rz-danger); font-size: 1.2rem;" />
                <RadzenText TextStyle="TextStyle.H6" class="rz-m-0">Live Now</RadzenText>
            </RadzenStack>
            <RadzenButton Icon="refresh" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.ExtraSmall" Variant="Variant.Flat" Click="@RefreshAllRecordings" IsBusy="@_isRefreshing" />
        </RadzenStack>

        <RadzenDataGrid Data="@_activeRecordings" TItem="ActiveRecordingInfo" Density="Density.Compact" AllowPaging="true" PageSize="5" Responsive="true" class="rz-border-radius-1">
            <EmptyTemplate>
                <div class="rz-p-4 rz-text-align-center">
                    <RadzenText TextStyle="TextStyle.Body2" Text="No active recordings." />
                </div>
            </EmptyTemplate>
            <Columns>
                <RadzenDataGridColumn TItem="ActiveRecordingInfo" Title="User">
                    <Template Context="info">
                        <strong>@info.Username</strong>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="ActiveRecordingInfo" Title="Time" Width="80px" HeaderCssClass="mobile-hide" CssClass="mobile-hide">
                    <Template Context="info">
                        <RadzenText TextStyle="TextStyle.Caption" Text="@info.Started_At.ToLocalTime().ToString("HH:mm")" />
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="ActiveRecordingInfo" Title="Dur" Width="80px">
                    <Template Context="info">
                        <RadzenBadge Text="@FormatActiveDuration(info.Started_At)" BadgeStyle="BadgeStyle.Danger" Variant="Variant.Flat" IsPill="true" />
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="ActiveRecordingInfo" Title="Size" Width="80px" HeaderCssClass="mobile-hide" CssClass="mobile-hide">
                    <Template Context="info">
                        <RadzenText TextStyle="TextStyle.Caption">@FormatSize(info.Size_Bytes)</RadzenText>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="ActiveRecordingInfo" Title="" Width="60px" TextAlign="TextAlign.Right">
                    <Template Context="info">
                        <RadzenButton Icon="stop" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.ExtraSmall" Variant="Variant.Flat" Click="@(args => StopRecording(info.Username))" />
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </RadzenCard>

    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Gap="0.5rem" class="rz-mb-2">
        <RadzenText TextStyle="TextStyle.H6" class="rz-m-0">Files</RadzenText>
        <RadzenButton Icon="refresh" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.ExtraSmall" Variant="Variant.Flat" Click="@RefreshFiles" IsBusy="@_isRefreshing" />
    </RadzenStack>
    <RadzenDataGrid Data="@_files" TItem="VideoFileInfo" AllowPaging="true" PageSize="10" Density="Density.Compact" Responsive="true" class="rz-border-radius-1">
        <EmptyTemplate>
            <div class="rz-p-8 rz-text-align-center">
                <RadzenText TextStyle="TextStyle.Subtitle2" Text="No files found." />
            </div>
        </EmptyTemplate>
        <Columns>
            <RadzenDataGridColumn TItem="VideoFileInfo" Title="Name">
                <Template Context="file">
                    <RadzenText TextStyle="TextStyle.Caption" Style="word-break: break-all; font-weight: bold;">@file.Name</RadzenText>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="VideoFileInfo" Title="Size" Width="70px" HeaderCssClass="mobile-hide" CssClass="mobile-hide">
                <Template Context="file">
                    <RadzenText TextStyle="TextStyle.Caption">@FormatSize(file.SizeBytes)</RadzenText>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="VideoFileInfo" Title="Dur" Width="70px" HeaderCssClass="mobile-hide" CssClass="mobile-hide">
                <Template Context="file">
                    <RadzenText TextStyle="TextStyle.Caption">@FormatDuration(file.DurationSeconds)</RadzenText>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="VideoFileInfo" Title="" Width="90px" TextAlign="TextAlign.Right">
                <Template Context="file">
                    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.25rem">
                        <RadzenButton Icon="download" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.ExtraSmall" 
                                      Click="@(args => JSRuntime.InvokeVoidAsync("open", RecorderClient.GetDownloadUrl(file.Name), "_blank"))" />
                        <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.ExtraSmall" Click="@(args => DeleteFile(file.Name))" />
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
}
else
{
    <div class="rz-p-12 rz-text-align-center">
        <RadzenIcon Icon="lock" Style="font-size: 4rem; color: var(--rz-danger);" />
        <RadzenText TextStyle="TextStyle.H5" Text="Access Denied" class="rz-mt-4" />
        <RadzenText TextStyle="TextStyle.Body1" Text="You must be logged in as admin to access this page." />
        <RadzenButton Text="Login here" ButtonStyle="ButtonStyle.Primary" class="rz-mt-4" Click="@(() => NavManager.NavigateTo("/login"))" />
    </div>
}

@code {
    private List<TikTokAccount> accounts = new();
    private string newUsername = "";
    private string statusMessage = "";
    private System.Threading.Timer? _timer;
    private List<VideoFileInfo> _files = new();
    private List<ActiveRecordingInfo> _activeRecordings = new();
    private int _refreshTick = 0;
    private bool _disposed = false;
    private bool _isRefreshing = false;
    private string currentSessionId = "";
    private string newSessionId = "";
    private bool isSessionIdFromConfig = false;

    protected override async Task OnInitializedAsync()
    {
        if (AdminSession.IsAdmin)
        {
            await LoadAccounts();
            await RefreshAllRecordings();
            await LoadSettings();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && AdminSession.IsAdmin && !_disposed)
        {
            // Updated to 1s as requested by user to see real-time duration updates
            _timer = new System.Threading.Timer(OnTimerCallback, null, 1000, 1000);
        }
        await Task.CompletedTask;
    }

    private async Task LoadAccounts()
    {
        if (_disposed) return;
        accounts = TrackerService.CachedAccounts.ToList();
        await Task.CompletedTask;
    }

    private void OnTimerCallback(object? state)
    {
        if (_disposed) return;

        InvokeAsync(async () =>
        {
            try 
            {
                if (_disposed) return;

                await LoadAccounts();
                
                await RefreshAllRecordings();
                
                if (!_disposed)
                {
                    StateHasChanged();
                }
            }
            catch (Exception)
            {
                // Silent catch for secondary render errors during disposal
            }
        });
    }

    private async Task RefreshAllRecordings()
    {
        if (_isRefreshing) return;
        try
        {
            _isRefreshing = true;
            _activeRecordings = await RecorderClient.GetActiveRecordingsAsync();
            _files = await RecorderClient.ListRecordingsAsync();
        }
        finally
        {
            _isRefreshing = false;
        }
    }

    private async Task RefreshFiles()
    {
        if (_isRefreshing) return;
        try
        {
            _isRefreshing = true;
            _files = await RecorderClient.ListRecordingsAsync();
        }
        finally
        {
            _isRefreshing = false;
        }
    }

    private async Task DeleteFile(string filename)
    {
        var success = await RecorderClient.DeleteRecordingAsync(filename);
        if (success)
        {
            await RefreshFiles();
        }
    }

    private async Task StopRecording(string username)
    {
        await RecorderClient.StopRecordingAsync(username);
        await Task.Delay(500); 
        await RefreshAllRecordings();
    }

    private async Task OnToggleAccount(bool isChecked, TikTokAccount account)
    {
        // 1. Update local UI state immediately for responsiveness
        account.AutoRecord = isChecked;
        
        // 2. Call centralized service to update DB and shared cache atomically
        await TrackerService.UpdateAccountAutoRecordAsync(account.Id, isChecked);
        
        // 3. If turning on and already live, start recording immediately
        if (isChecked && account.IsOnline)
        {
            statusMessage = $"Starting recording for @{account.Username}...";
            await RecorderClient.StartRecordingAsync(account.Username);
            
            // Wait briefly for recorder to initialize process, then refresh lists
            await Task.Delay(1000);
            await RefreshAllRecordings();
            StateHasChanged();
        }
        
        statusMessage = $"Auto-record for @{account.Username} {(isChecked ? "enabled" : "disabled")}.";
    }

    private async Task OnRemoveAccount(MouseEventArgs args, TikTokAccount account)
    {
        var success = await TrackerService.RemoveAccountAsync(account.Id);
        if (success)
        {
            await LoadAccounts();
            statusMessage = $"@{account.Username} removed.";
        }
    }

    private async Task LoadSettings()
    {
        currentSessionId = await SettingsService.GetTikTokSessionIdAsync();
        // Check if it's the fallback or DB value
        await using var db = await DbFactory.CreateDbContextAsync();
        isSessionIdFromConfig = !await db.SystemSettings.AnyAsync(s => s.Key == "TikTokSessionId");
    }

    private async Task UpdateSessionId()
    {
        if (!string.IsNullOrWhiteSpace(newSessionId))
        {
            await SettingsService.UpdateTikTokSessionIdAsync(newSessionId.Trim());
            await LoadSettings();
            newSessionId = "";
            statusMessage = "TikTok Session ID updated successfully!";
        }
    }

    private async Task AddAccount(MouseEventArgs args)
    {
        if (!string.IsNullOrWhiteSpace(newUsername))
        {
            var username = newUsername.Trim().Replace("@", "");
            var (success, message) = await TrackerService.AddAccountAsync(username);
            
            if (success)
            {
                newUsername = "";
                await LoadAccounts();
            }
            
            statusMessage = message;
        }
    }

    private void Logout(MouseEventArgs args)
    {
        AdminSession.Logout();
        NavManager.NavigateTo("/");
    }

    private string FormatSize(long bytes)
    {
        string[] units = { "B", "KB", "MB", "GB", "TB" };
        int unitIndex = 0;
        double size = bytes;
        while (size >= 1024 && unitIndex < units.Length - 1)
        {
            size /= 1024;
            unitIndex++;
        }
        return $"{size:F1} {units[unitIndex]}";
    }

    private string FormatDuration(double? seconds)
    {
        if (!seconds.HasValue) return "??:??";
        var ts = TimeSpan.FromSeconds(seconds.Value);
        if (ts.TotalHours >= 1)
            return ts.ToString(@"hh\:mm\:ss");
        return ts.ToString(@"mm\:ss");
    }

    private string FormatActiveDuration(DateTime startedAt)
    {
        var duration = DateTime.Now - startedAt;
        if (duration.TotalHours >= 1)
            return duration.ToString(@"hh\:mm\:ss");
        return duration.ToString(@"mm\:ss");
    }

    public void Dispose()
    {
        _disposed = true;
        _timer?.Dispose();
    }
}
