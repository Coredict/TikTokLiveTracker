@page "/admin"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using TikTokTracker.Web.Data
@using TikTokTracker.Web.Models
@using TikTokTracker.Web.Services
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AdminSessionService AdminSession
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@implements IDisposable

<PageTitle>Admin Panel</PageTitle>

@if (!AdminSession.IsAdmin)
{
    <div class="container mt-4">
        <div class="alert alert-danger">
            You must be logged in as admin to access this page. <a href="/login">Login here</a>.
        </div>
    </div>
    return;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Admin Panel - Tracked Accounts</h2>
        <button class="btn btn-outline-secondary btn-sm" @onclick="Logout">Logout</button>
    </div>

    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <h5 class="card-title">Add New Account</h5>
            <div class="input-group">
                <input type="text" class="form-control" @bind="newUsername" placeholder="TikTok Username (without @@)" />
                <button class="btn btn-success" @onclick="AddAccount">Add Account</button>
            </div>
            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <div class="mt-2 alert alert-info py-1">@statusMessage</div>
            }
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Username</th>
                    <th>Status</th>
                    <th>Coins</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (accounts == null)
                {
                    <tr><td colspan="4" class="text-center">Loading...</td></tr>
                }
                else if (!accounts.Any())
                {
                    <tr><td colspan="4" class="text-center">No accounts tracked yet.</td></tr>
                }
                else
                {
                    @foreach (var account in accounts)
                    {
                        <tr>
                            <td><strong>@account.Username</strong></td>
                            <td>
                                @if (account.IsOnline)
                                {
                                    <span class="badge bg-success">Online</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Offline</span>
                                }
                            </td>
                            <td>@account.CurrentCoins.ToString("N0")</td>
                            <td>
                                <button class="btn btn-danger btn-sm" @onclick="() => RemoveAccount(account)">
                                    <i class="bi bi-trash"></i> Remove
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <hr class="my-5" />

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Recent Gifts Feed</h3>
        <div>
            <button class="btn btn-sm btn-outline-info me-2" @onclick="ExportGifts">Export JSON</button>
            <button class="btn btn-sm btn-outline-primary" @onclick="LoadRecentGifts">Refresh Feed</button>
        </div>
    </div>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-sm table-hover align-middle bg-white">
            <thead class="table-light">
                <tr>
                    <th>Time</th>
                    <th>To (Tracked)</th>
                    <th>Sender</th>
                    <th>Gift</th>
                    <th>Amount</th>
                    <th>Diamonds</th>
                </tr>
            </thead>
            <tbody>
                @if (recentGifts == null)
                {
                    <tr><td colspan="6" class="text-center py-3 text-muted italic">Loading gifts...</td></tr>
                }
                else if (!recentGifts.Any())
                {
                    <tr><td colspan="6" class="text-center py-3 text-muted">No gifts recorded yet.</td></tr>
                }
                else
                {
                    @foreach (var gift in recentGifts)
                    {
                        <tr>
                            <td class="text-muted" style="font-size: 0.85rem;">@gift.Timestamp.ToLocalTime().ToString("HH:mm:ss")</td>
                            <td><span class="badge bg-secondary">@@@gift.Account?.Username</span></td>
                            <td>
                                <strong>@gift.SenderNickname</strong>
                                <br />
                                <small class="text-muted">@@@gift.SenderUsername</small>
                            </td>
                            <td>@gift.GiftName</td>
                            <td>@gift.Amount</td>
                            <td>
                                <span class="text-warning">💎</span> @gift.TotalDiamonds.ToString("N0")
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (totalGiftsCount > pageSize)
    {
        <div class="d-flex justify-content-between align-items-center mt-2 px-2 pb-4">
            <div class="text-muted small">
                Showing @((currentPage - 1) * pageSize + 1) to @(Math.Min(currentPage * pageSize, totalGiftsCount)) of @totalGiftsCount
            </div>
            <nav aria-label="Gift navigation">
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <button class="page-link shadow-none" @onclick="() => ChangePage(currentPage - 1)">Previous</button>
                    </li>
                    <li class="page-item disabled">
                        <span class="page-link text-dark bg-light border-0">Page @currentPage of @(Math.Ceiling((double)totalGiftsCount / pageSize))</span>
                    </li>
                    <li class="page-item @(currentPage * pageSize >= totalGiftsCount ? "disabled" : "")">
                        <button class="page-link shadow-none" @onclick="() => ChangePage(currentPage + 1)">Next</button>
                    </li>
                </ul>
            </nav>
        </div>
    }

    <hr class="my-5" />

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Top Gifters (All Time)</h3>
        <div>
            <button class="btn btn-sm btn-outline-info me-2" @onclick="ExportSummaries">Export JSON</button>
            <button class="btn btn-sm btn-outline-info" @onclick="LoadTopGifters">Refresh Leaderboard</button>
        </div>
    </div>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-sm table-hover align-middle bg-white">
            <thead class="table-light">
                <tr>
                    <th>Recipient</th>
                    <th>Sender</th>
                    <th>Total Diamonds</th>
                    <th>Gift Count</th>
                    <th>Last Gift</th>
                </tr>
            </thead>
            <tbody>
                @if (topGifters == null)
                {
                    <tr><td colspan="5" class="text-center py-3 text-muted italic">Loading stats...</td></tr>
                }
                else if (!topGifters.Any())
                {
                    <tr><td colspan="5" class="text-center py-3 text-muted">No summaries recorded yet.</td></tr>
                }
                else
                {
                    @foreach (var summary in topGifters)
                    {
                        <tr>
                            <td><span class="badge bg-dark">@@@summary.Account?.Username</span></td>
                            <td>
                                <strong>@summary.SenderNickname</strong>
                                <br />
                                <small class="text-muted">@@@summary.SenderUsername</small>
                            </td>
                            <td>
                                <span class="text-warning">💎</span> <strong>@summary.TotalDiamonds.ToString("N0")</strong>
                            </td>
                            <td>@summary.TotalGifts.ToString("N0")</td>
                            <td class="text-muted" style="font-size: 0.85rem;">@summary.LastGiftTime.ToLocalTime().ToString("MMM dd, HH:mm")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<TikTokAccount>? accounts;
    private List<GiftTransaction>? recentGifts;
    private List<GifterSummary>? topGifters;
    private string newUsername = "";
    private string statusMessage = "";
    private System.Threading.Timer? _timer;

    // Pagination for Recent Gifts
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalGiftsCount = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadAccounts();

        _timer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await LoadAccounts();
                StateHasChanged();
            });
        }, null, 1000, 1000);
    }

    private async Task LoadAccounts()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        accounts = await db.Accounts.ToListAsync();
        await LoadRecentGifts();
        await LoadTopGifters();
    }

    private async Task LoadTopGifters()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        topGifters = await db.GifterSummaries
            .Include(g => g.Account)
            .OrderByDescending(g => g.TotalDiamonds)
            .Take(50)
            .ToListAsync();
    }

    private async Task LoadRecentGifts()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        
        totalGiftsCount = await db.Gifts.CountAsync();
        
        // Ensure current page is valid after potential cleanups
        var maxPage = (int)Math.Max(1, Math.Ceiling((double)totalGiftsCount / pageSize));
        if (currentPage > maxPage) currentPage = maxPage;

        recentGifts = await db.Gifts
            .Include(g => g.Account)
            .OrderByDescending(g => g.Timestamp)
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToListAsync();
    }

    private async Task ChangePage(int newPage)
    {
        currentPage = newPage;
        await LoadRecentGifts();
    }

    private async Task ExportGifts()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var gifts = await db.Gifts
            .Include(g => g.Account)
            .OrderByDescending(g => g.Timestamp)
            .Select(g => new {
                Time = g.Timestamp.ToLocalTime(),
                To = g.Account != null ? "@" + g.Account.Username : "N/A",
                SenderNickname = g.SenderNickname,
                SenderUsername = "@" + g.SenderUsername,
                Gift = g.GiftName,
                Amount = g.Amount,
                Diamonds = g.TotalDiamonds
            })
            .ToListAsync();
        
        var json = System.Text.Json.JsonSerializer.Serialize(gifts, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        await JSRuntime.InvokeVoidAsync("saveAsFile", $"recent_gifts_{DateTime.Now:yyyyMMdd_HHmm}.json", json);
    }

    private async Task ExportSummaries()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var summaries = await db.GifterSummaries
            .Include(g => g.Account)
            .OrderByDescending(g => g.TotalDiamonds)
            .Select(s => new {
                Recipient = s.Account != null ? "@" + s.Account.Username : "N/A",
                SenderNickname = s.SenderNickname,
                SenderUsername = "@" + s.SenderUsername,
                TotalDiamonds = s.TotalDiamonds,
                TotalGifts = s.TotalGifts,
                LastGift = s.LastGiftTime.ToLocalTime()
            })
            .ToListAsync();
        
        var json = System.Text.Json.JsonSerializer.Serialize(summaries, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        await JSRuntime.InvokeVoidAsync("saveAsFile", $"top_gifters_{DateTime.Now:yyyyMMdd_HHmm}.json", json);
    }

    private async Task AddAccount()
    {
        if (!string.IsNullOrWhiteSpace(newUsername))
        {
            var username = newUsername.Trim().Replace("@", "");
            await using var db = await DbFactory.CreateDbContextAsync();
            if (!await db.Accounts.AnyAsync(a => a.Username == username))
            {
                db.Accounts.Add(new TikTokAccount { Username = username });
                await db.SaveChangesAsync();
                newUsername = "";
                statusMessage = $"@{username} added!";
                await LoadAccounts();
            }
            else
            {
                statusMessage = $"@{username} is already being tracked.";
            }
        }
    }

    private async Task RemoveAccount(TikTokAccount account)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var existing = await db.Accounts.FindAsync(account.Id);
        if (existing != null)
        {
            db.Accounts.Remove(existing);
            await db.SaveChangesAsync();
        }
        statusMessage = $"@{account.Username} removed.";
        await LoadAccounts();
    }

    private void Logout()
    {
        AdminSession.Logout();
        NavManager.NavigateTo("/");
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }
}
