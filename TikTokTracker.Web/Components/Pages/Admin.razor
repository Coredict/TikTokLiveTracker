@page "/admin"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using TikTokTracker.Web.Data
@using TikTokTracker.Web.Models
@using TikTokTracker.Web.Services
@inject IDbContextFactory<AppDbContext> DbFactory
@inject AdminSessionService AdminSession
@inject NavigationManager NavManager
@implements IDisposable

<PageTitle>Admin Panel</PageTitle>

@if (!AdminSession.IsAdmin)
{
    <div class="container mt-4">
        <div class="alert alert-danger">
            You must be logged in as admin to access this page. <a href="/login">Login here</a>.
        </div>
    </div>
    return;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Admin Panel - Tracked Accounts</h2>
        <button class="btn btn-outline-secondary btn-sm" @onclick="Logout">Logout</button>
    </div>

    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <h5 class="card-title">Add New Account</h5>
            <div class="input-group">
                <input type="text" class="form-control" @bind="newUsername" placeholder="TikTok Username (without @@)" />
                <button class="btn btn-success" @onclick="AddAccount">Add Account</button>
            </div>
            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <div class="mt-2 alert alert-info py-1">@statusMessage</div>
            }
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Username</th>
                    <th>Status</th>
                    <th>Coins</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (accounts == null)
                {
                    <tr><td colspan="4" class="text-center">Loading...</td></tr>
                }
                else if (!accounts.Any())
                {
                    <tr><td colspan="4" class="text-center">No accounts tracked yet.</td></tr>
                }
                else
                {
                    @foreach (var account in accounts)
                    {
                        <tr>
                            <td><strong>@account.Username</strong></td>
                            <td>
                                @if (account.IsOnline)
                                {
                                    <span class="badge bg-success">Online</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Offline</span>
                                }
                            </td>
                            <td>@account.CurrentCoins.ToString("N0")</td>
                            <td>
                                <button class="btn btn-danger btn-sm" @onclick="() => RemoveAccount(account)">
                                    <i class="bi bi-trash"></i> Remove
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <hr class="my-5" />

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Recent Gifts Feed</h3>
        <button class="btn btn-sm btn-outline-primary" @onclick="LoadRecentGifts">Refresh Feed</button>
    </div>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-sm table-hover align-middle bg-white">
            <thead class="table-light">
                <tr>
                    <th>Time</th>
                    <th>To (Tracked)</th>
                    <th>Sender</th>
                    <th>Gift</th>
                    <th>Amount</th>
                    <th>Diamonds</th>
                </tr>
            </thead>
            <tbody>
                @if (recentGifts == null)
                {
                    <tr><td colspan="6" class="text-center py-3 text-muted italic">Loading gifts...</td></tr>
                }
                else if (!recentGifts.Any())
                {
                    <tr><td colspan="6" class="text-center py-3 text-muted">No gifts recorded yet.</td></tr>
                }
                else
                {
                    @foreach (var gift in recentGifts)
                    {
                        <tr>
                            <td class="text-muted" style="font-size: 0.85rem;">@gift.Timestamp.ToLocalTime().ToString("HH:mm:ss")</td>
                            <td><span class="badge bg-secondary">@@@gift.Account?.Username</span></td>
                            <td>
                                <strong>@gift.SenderNickname</strong>
                                <br />
                                <small class="text-muted">@@@gift.SenderUsername</small>
                            </td>
                            <td>@gift.GiftName</td>
                            <td>x@gift.Amount</td>
                            <td>
                                <span class="text-warning">💎</span> @gift.TotalDiamonds.ToString("N0")
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<TikTokAccount>? accounts;
    private List<GiftTransaction>? recentGifts;
    private string newUsername = "";
    private string statusMessage = "";
    private System.Threading.Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await LoadAccounts();

        _timer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await LoadAccounts();
                StateHasChanged();
            });
        }, null, 1000, 1000);
    }

    private async Task LoadAccounts()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        accounts = await db.Accounts.ToListAsync();
        await LoadRecentGifts();
    }

    private async Task LoadRecentGifts()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        recentGifts = await db.Gifts
            .Include(g => g.Account)
            .OrderByDescending(g => g.Timestamp)
            .Take(20)
            .ToListAsync();
    }

    private async Task AddAccount()
    {
        if (!string.IsNullOrWhiteSpace(newUsername))
        {
            var username = newUsername.Trim().Replace("@", "");
            await using var db = await DbFactory.CreateDbContextAsync();
            if (!await db.Accounts.AnyAsync(a => a.Username == username))
            {
                db.Accounts.Add(new TikTokAccount { Username = username });
                await db.SaveChangesAsync();
                newUsername = "";
                statusMessage = $"@{username} added!";
                await LoadAccounts();
            }
            else
            {
                statusMessage = $"@{username} is already being tracked.";
            }
        }
    }

    private async Task RemoveAccount(TikTokAccount account)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var existing = await db.Accounts.FindAsync(account.Id);
        if (existing != null)
        {
            db.Accounts.Remove(existing);
            await db.SaveChangesAsync();
        }
        statusMessage = $"@{account.Username} removed.";
        await LoadAccounts();
    }

    private void Logout()
    {
        AdminSession.Logout();
        NavManager.NavigateTo("/");
    }

    public void Dispose()
    {
        _timer?.Dispose();
    }
}
