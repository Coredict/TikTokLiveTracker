@page "/login"
@rendermode InteractiveServer
@using TikTokTracker.Web.Services
@using Radzen
@using Radzen.Blazor
@inject AdminSessionService AdminSession
@inject IConfiguration Config
@inject NavigationManager NavManager

<PageTitle>Admin Login</PageTitle>

<RadzenRow JustifyContent="JustifyContent.Center" class="rz-mt-12">
    <RadzenColumn Size="12" SizeMD="4">
        <RadzenCard class="rz-p-8">
            <RadzenStack AlignItems="AlignItems.Center" Gap="1.5rem">
                <RadzenIcon Icon="lock" Style="font-size: 3rem;" />
                <RadzenText TextStyle="TextStyle.H5" Text="Admin Login" class="rz-m-0" />

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" Shade="Shade.Lighter" class="rz-w-100">@errorMessage</RadzenAlert>
                }

                <RadzenStack Gap="0.5rem" class="rz-w-100">
                    <RadzenText TextStyle="TextStyle.Overline" Text="Password" class="rz-m-0" />
                    <RadzenPassword @bind-Value="@password" @onkeyup="OnKeyUp" class="rz-w-100" />
                </RadzenStack>

                <RadzenButton Text="Login" ButtonStyle="ButtonStyle.Primary" class="rz-w-100" Click="@HandleLogin" />
            </RadzenStack>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>

@code {
    private string password = "";
    private string errorMessage = "";

    private void OnPasswordChange(string value)
    {
        password = value;
    }

    private async Task OnKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await HandleLogin();
    }

    private async Task HandleLogin()
    {
        var expected = Config.GetValue<string>("AdminPassword") ?? "";
        if (AdminSession.Login(password, expected))
        {
            NavManager.NavigateTo("/admin");
        }
        else
        {
            expected = Config.GetValue<string>("AdminPassword") ?? "";
            errorMessage = $"Invalid password. (Expected length: {expected.Length})";
        }
        await Task.CompletedTask;
    }
}
