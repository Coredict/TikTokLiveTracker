@page "/login"
@rendermode InteractiveServer
@using TikTokTracker.Web.Services
@inject AdminSessionService AdminSession
@inject IConfiguration Config
@inject NavigationManager NavManager

<PageTitle>Admin Login</PageTitle>

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm" style="background-color: var(--discord-bg-darker); color: var(--discord-text);">
            <div class="card-body p-4">
                <h3 class="card-title text-center mb-4 text-white"><i class="bi bi-shield-lock"></i> Admin Login</h3>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger py-2">@errorMessage</div>
                }

                <div class="mb-4">
                    <label class="form-label small fw-bold text-muted text-uppercase">Password</label>
                    <input type="password" @bind="password" @onkeyup="OnKeyUp" class="form-control border-0 text-white" style="background-color: var(--discord-bg-deep);" />
                </div>

                <button class="btn btn-primary w-100 fw-bold py-2" @onclick="HandleLogin">Login</button>
            </div>
        </div>
    </div>
</div>

@code {
    private string password = "";
    private string errorMessage = "";

    private async Task OnKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await HandleLogin();
    }

    private async Task HandleLogin()
    {
        var expected = Config.GetValue<string>("AdminPassword") ?? "";
        if (AdminSession.Login(password, expected))
        {
            NavManager.NavigateTo("/admin");
        }
        else
        {
            errorMessage = "Invalid password";
        }
        await Task.CompletedTask;
    }
}
